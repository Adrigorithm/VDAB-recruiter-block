{
  "manifest_version": 3,
  "name": "VDAB Recruiter Block",
  "version": "1.0",
  "homepage_url": "https://github.com/Adrigorithm/VDAB-recruiter-block",
  "description": "Blocks vacancies posted by these pesky recruiting companies for the most popular job posting website(s) in Belgium.",

  "icons": {
    "48": "icon.svg",
    "96": "icon.svg"
  },

  "permissions": ["activeTab"],

  "browser_specific_settings": {
    "gecko": {
      "id": "vdab_recruiter_block@mozilla.org",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "action": {
    "default_icon": "icon.svg",
    "default_title": "VDAB Recruiter Block",
    "default_popup": "popup/popup.html"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.vdab.be/vindeenjob/vacatures?*",
        "https://www.vdab.be/vindeenjob/prive/suggesties*"
      ],
      "js": ["script.js"]
    }
  ]
}
